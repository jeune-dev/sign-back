{
  "name": "sign-api",
  "version": "1.0.0",
  "description": "Sign App — backend API Node.js/Express",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:status": "sequelize-cli db:migrate:status",
    "seed:admin": "node -r dotenv/config src/scripts/seedAdmin.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop sign-api",
    "pm2:reload": "pm2 reload ecosystem.config.js --env production --update-env",
    "pm2:logs": "pm2 logs sign-api",
    "pm2:status": "pm2 status sign-api",
    "docker:dev": "docker compose up --build",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f backend",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "backup": "bash deploy/backup-postgres.sh",
    "test": "echo \"No tests configured\" && exit 0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.826.0",
    "@aws-sdk/s3-request-presigner": "^3.826.0",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@sparticuz/chromium": "^121.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^14.0.0",
    "hellosign-sdk": "^2.1.0",
    "helmet": "^8.1.0",
    "html-pdf": "^3.0.1",
    "html-pdf-node": "^1.0.8",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "puppeteer": "^24.36.1",
    "resend": "^6.9.3",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.5",
    "sharp": "^0.34.5",
    "sib-api-v3-sdk": "^8.5.0",
    "twilio": "^5.11.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
