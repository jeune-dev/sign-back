# ============================================================
#  Sign API — Variables d'environnement
#  Copier ce fichier en .env et remplir toutes les valeurs.
#  NE JAMAIS committer le fichier .env.
# ============================================================

# ── Serveur ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Logs ─────────────────────────────────────────────────────
# Chemin absolu du dossier de logs (cree automatiquement si absent en production)
# Defaut : <racine_projet>/logs
LOG_DIR=/var/www/sign-api/logs
LOG_LEVEL=info

# ── Base de donnees PostgreSQL ────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=signapp
DB_USER=signuser
DB_PASSWORD=CHANGE_MOI_MOT_DE_PASSE_FORT

# SSL PostgreSQL : laisser vide si PostgreSQL est sur le meme serveur (loopback)
# Sinon : contenu du certificat CA en base64
DB_SSL_CA=

# ── JWT ──────────────────────────────────────────────────────
# Generer : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_MOI_SECRET_JWT_64_CHARS_MIN
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=CHANGE_MOI_REFRESH_SECRET_DIFFERENT
JWT_RESET_SECRET=CHANGE_MOI_RESET_SECRET_DIFFERENT

# ── CORS ─────────────────────────────────────────────────────
# URL de l'app mobile / front — JAMAIS * en production
# Plusieurs origines : CORS_ORIGIN=https://app.signapp.com,https://admin.signapp.com
CORS_ORIGIN=https://YOUR_DOMAIN

# URL du frontend (utilisée pour les liens dans les emails, etc.)
FRONTEND_URL=https://YOUR_DOMAIN

# ── Admin par defaut ─────────────────────────────────────────
# Cree au 1er demarrage si absent. Obligatoire de changer ces valeurs.
ADMIN_EMAIL=admin@votre-domaine.com
ADMIN_PASSWORD=ChangeMe_MotDePasseForte123!
ADMIN_NOM=Admin
ADMIN_PRENOM=Sign
ADMIN_ADRESSE=Dakar, Senegal

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MAIL_FROM=SignApp <noreply@votre-domaine.com>

# ── SMTP (alternative a Resend) ──────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=

# ── Cloudflare R2 ─────────────────────────────────────────────
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=sign-app
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Firebase FCM (notifications push) ─────────────────────────
# Contenu JSON du fichier serviceAccount Firebase sur une seule ligne
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── HelloSign ─────────────────────────────────────────────────
HELLOSIGN_API_KEY=

# ── PM2 ──────────────────────────────────────────────────────
# Nombre d'instances PM2 : "max" = 1 par coeur CPU | 1 = single process
PM2_INSTANCES=max
