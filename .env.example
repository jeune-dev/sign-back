PORT=3000
NODE_ENV=development

# ── Base de données ──────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=signapp
DB_USER=signuser
DB_PASSWORD=signpassword
DB_SSL_CA=

# ── JWT ──────────────────────────────────────────
JWT_SECRET=change_me_secret_jwt
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_RESET_SECRET=change_me_reset_secret

# ── CORS ─────────────────────────────────────────
CORS_ORIGIN=*
FRONTEND_URL=http://localhost:3000

# ── Admin par défaut ─────────────────────────────
ADMIN_EMAIL=admin@signapp.com
ADMIN_PASSWORD=Admin1234!
ADMIN_NOM=Admin
ADMIN_PRENOM=Sign
ADMIN_ADRESSE=Dakar, Sénégal

# ── Email (Resend) ────────────────────────────────
RESEND_API_KEY=
MAIL_FROM=SignApp <onboarding@resend.dev>

# ── SMTP (optionnel) ──────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=

# ── Cloudflare R2 ─────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sign-app
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Firebase FCM ──────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── HelloSign ─────────────────────────────────────
HELLOSIGN_API_KEY=
